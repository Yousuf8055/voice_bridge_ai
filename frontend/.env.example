# Vercel Deployment Environment Variables
# Create a .env file locally, or paste these into Vercel's Environment Variables dashboard

# The WebSocket URL of your deployed Hugging Face Space backend
# e.g., wss://your-username-your-space-name.hf.space/ws/stream-stt/
VITE_WS_URL=wss://your-username-your-space-name.hf.space/ws/stream-stt/
